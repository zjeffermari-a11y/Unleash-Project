rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable) - Firebase Auth UID
    //   - displayName: string (required) - Artist's display name
    //   - photoURL: string (optional) - URL to artist's avatar
    //   - bio: string (optional) - Short biography
    //   - role: string (required, immutable unless admin) - User role
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: artworks
    // Document ID: {artworkId}
    // Fields:
    //   - title: string (required, max 100 chars) - Title of the artwork
    //   - description: string (optional, max 1000 chars) - Description of the artwork
    //   - category: string (required, enum) - Category of the artwork
    //   - imageUrl: string (required, valid URL) - URL of the artwork image
    //   - privacy: string (required, enum) - Privacy setting ('public', 'private')
    //   - authorId: string (required, immutable) - UID of the artist
    //   - authorName: string (required) - Display name of the artist
    //   - authorPhoto: string (optional) - Photo URL of the artist
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function isValidUrl(url) {
      return url is string && url.size() > 0 && url.size() <= 1048487;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "zjeffermari@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser() {
      let data = request.resource.data;
      return hasRequiredFields(['uid', 'displayName', 'role', 'createdAt']) &&
             validStringLength('displayName', 1, 500) &&
             isValidOptionalString('photoURL', 0, 1048487) &&
             isValidOptionalString('coverURL', 0, 1048487) &&
             isValidOptionalString('bio', 0, 1000) &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidArtwork() {
      let data = request.resource.data;
      return hasRequiredFields(['title', 'category', 'imageUrl', 'privacy', 'authorId', 'authorName', 'createdAt']) &&
             validStringLength('title', 1, 500) &&
             isValidOptionalString('description', 0, 2000) &&
             data.category in ['Painting', 'Sculpting', 'Digital', 'Photography', 'Other'] &&
             isValidUrl(data.imageUrl) &&
             data.privacy in ['public', 'private'] &&
             data.authorId == request.auth.uid &&
             validStringLength('authorName', 1, 500) &&
             isValidOptionalString('authorPhoto', 0, 2000) &&
             data.createdAt is timestamp;
    }

    function isValidEvent() {
      let data = request.resource.data;
      return hasRequiredFields(['title', 'description', 'date', 'location', 'hostId', 'hostName', 'imageUrl', 'type', 'status', 'createdAt']) &&
             validStringLength('title', 1, 500) &&
             validStringLength('description', 1, 5000) &&
             data.date is timestamp &&
             validStringLength('location', 1, 500) &&
             data.hostId == request.auth.uid &&
             validStringLength('hostName', 1, 500) &&
             isValidUrl(data.imageUrl) &&
             data.type in ['Event', 'Workshop'] &&
             data.status in ['upcoming', 'ongoing', 'past'] &&
             data.createdAt is timestamp;
    }

    function isValidMarketItem() {
      let data = request.resource.data;
      return hasRequiredFields(['title', 'description', 'price', 'category', 'type', 'sellerId', 'sellerName', 'imageUrl', 'status', 'createdAt']) &&
             validStringLength('title', 1, 500) &&
             validStringLength('description', 1, 5000) &&
             data.price is number && data.price >= 0 &&
             data.category in ['Painting', 'Sculpting', 'Digital', 'Photography', 'Other'] &&
             data.type in ['Physical', 'Digital'] &&
             data.sellerId == request.auth.uid &&
             validStringLength('sellerName', 1, 500) &&
             isValidUrl(data.imageUrl) &&
             data.status in ['available', 'sold'] &&
             data.createdAt is timestamp;
    }

    // ── Order validator ────────────────────────────────────────────────────────
    // Ensures the order document has the required shape before it is written.
    // Defence-in-depth: client-side cart store also validates before calling addDoc.
    function isValidOrder() {
      let data = request.resource.data;
      return hasRequiredFields(['buyerId', 'buyerName', 'items', 'total', 'status', 'createdAt']) &&
             // Buyer identity — must match the authenticated user (prevents spoofing)
             data.buyerId == request.auth.uid &&
             validStringLength('buyerName', 1, 500) &&
             // Items must be a non-empty list
             data.items is list &&
             data.items.size() > 0 &&
             // Total must be a positive monetary value
             data.total is number &&
             data.total > 0 &&
             // Status is always 'pending' on creation
             data.status == 'pending' &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      
      allow create: if isAuthenticated() && 
                    isOwner(userId) && 
                    isValidUser() && 
                    uidUnchanged() &&
                    (request.resource.data.role == 'user' || isAdmin());
                    
      allow update: if isAuthenticated() && 
                    isOwner(userId) && 
                    isValidUser() && 
                    uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    (request.resource.data.role == resource.data.role || isAdmin());
                    
      allow delete: if isAdmin();
    }

    match /artworks/{artworkId} {
      allow read: if resource.data.privacy == 'public' || isDocOwner();
      
      allow create: if isAuthenticated() && 
                    isValidArtwork();
                    
      allow update: if isDocOwner() && 
                    isValidArtwork() &&
                    request.resource.data.authorId == resource.data.authorId &&
                    request.resource.data.createdAt == resource.data.createdAt;
                    
      allow delete: if isDocOwner() || isAdmin();

      // ── Likes subcollection ──────────────────────────────────────────
      // Publicly readable so anyone can see like counts (onSnapshot).
      // A user can only write/delete their own like document.
      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }

      // ── Comments subcollection ───────────────────────────────────────
      // Publicly readable; authenticated users can post.
      // Only the comment author can delete their own comment.
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated() && request.auth.uid == resource.data.authorId;
      }
    }

    match /events/{eventId} {
      allow read: if true;
      
      allow create: if isAuthenticated() && 
                    isValidEvent();
                    
      allow update: if isAuthenticated() && 
                    request.auth.uid == resource.data.hostId &&
                    isValidEvent() &&
                    request.resource.data.hostId == resource.data.hostId &&
                    request.resource.data.createdAt == resource.data.createdAt;
                    
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.hostId || isAdmin());
    }

    match /marketItems/{itemId} {
      allow read: if true;
      
      allow create: if isAuthenticated() && 
                    isValidMarketItem();
                    
      allow update: if isAuthenticated() && 
                    request.auth.uid == resource.data.sellerId &&
                    isValidMarketItem() &&
                    request.resource.data.sellerId == resource.data.sellerId &&
                    request.resource.data.createdAt == resource.data.createdAt;
                    
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.sellerId || isAdmin());
    }

    // ── Orders collection ──────────────────────────────────────────────────────
    // Security model:
    //   READ  — users can only fetch their own orders (buyerId == auth.uid)
    //   CREATE — users can only create orders for themselves, validated by isValidOrder()
    //   UPDATE — permanently denied; orders are immutable financial records
    //   DELETE — permanently denied; orders must be preserved for audit trails
    match /orders/{orderId} {
      // Scope reads to the document owner only — prevents users seeing other buyers' orders
      allow read: if isAuthenticated() &&
                    request.auth.uid == resource.data.buyerId;

      // Allow order creation only when:
      //   1. User is authenticated
      //   2. buyerId in the document matches the requesting user's UID
      //   3. The document shape is valid (isValidOrder)
      allow create: if isAuthenticated() &&
                      request.resource.data.buyerId == request.auth.uid &&
                      isValidOrder();

      // Hard deny — orders cannot be modified or removed after creation
      allow update: if false;
      allow delete: if false;
    }
    // ── Follows collection ─────────────────────────────────────────────────────
    // Security model:
    //   READ   — publicly readable so follower/following counts work for everyone
    //   CREATE — users can only create follow docs where followerId == their own uid
    //   DELETE — users can only delete their own follow docs
    //   UPDATE — permanently denied; follows are binary (exist or not)
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                      request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuthenticated() &&
                      resource.data.followerId == request.auth.uid;
      allow update: if false;
    }
  }
}

